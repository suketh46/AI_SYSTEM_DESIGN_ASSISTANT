# GitHub Models Configuration
# Generate a GitHub PAT at: https://github.com/settings/tokens
# Required scopes: none (GitHub Models uses a free-tier PAT with no special scopes)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_MODEL=gpt-4o
GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# JWT Secret — used to sign authentication tokens
# In production, generate a strong random secret (e.g. openssl rand -base64 32)
JWT_SECRET=dev-secret-change-in-production
